# ── Supabase (production / optional for local) ────────────────────────────────
# If both variables below are set, the app connects to Supabase.
# Leave them unset to use the local JSON file fallback instead.
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Local JSON DB (optional) ───────────────────────────────────────────────────
# Path to the local data file used when Supabase vars are not set.
# Defaults to local.db.json in the backend directory.
# DB_PATH=./local.db.json
